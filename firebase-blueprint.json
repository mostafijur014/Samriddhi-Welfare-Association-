{
  "entities": {
    "ContactPerson": {
      "title": "ContactPerson",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "imageUrl": { "type": "string" }
      }
    },
    "Member": {
      "title": "Member",
      "description": "A member of the savings group",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Full name of the member" },
        "memberId": { "type": "string", "description": "Unique identifier for the member" },
        "phone": { "type": "string", "description": "Phone number for direct calling" },
        "monthlyContribution": { "type": "number", "description": "Agreed monthly savings amount" },
        "yearlyFixedDeposit": { "type": "number", "description": "Fixed amount to be paid yearly" },
        "monthlyContributionHistory": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "amount": { "type": "number" },
              "startMonth": { "type": "string" }
            }
          }
        },
        "yearlyDepositHistory": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "amount": { "type": "number" },
              "startMonth": { "type": "string" }
            }
          }
        },
        "totalDeposited": { "type": "number", "description": "Total amount deposited so far (monthly)" },
        "totalYearlyPaid": { "type": "number", "description": "Total amount paid towards yearly fixed deposit" },
        "lastPaymentDate": { "type": "string", "format": "date", "description": "Date of the last deposit" },
        "status": { "type": "string", "enum": ["Active", "Inactive"], "description": "Current status of the member" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "memberId", "monthlyContribution", "totalDeposited", "status"]
    },
    "Profit": {
      "title": "Profit",
      "description": "A group profit record",
      "type": "object",
      "properties": {
        "description": { "type": "string", "description": "Description of the profit" },
        "amount": { "type": "number", "description": "Profit amount" },
        "date": { "type": "string", "format": "date-time", "description": "When the profit was recorded" }
      },
      "required": ["description", "amount", "date"]
    },
    "Expense": {
      "title": "Expense",
      "description": "A group expense record",
      "type": "object",
      "properties": {
        "description": { "type": "string", "description": "Description of the expense" },
        "amount": { "type": "number", "description": "Expense amount" },
        "date": { "type": "string", "format": "date-time", "description": "When the expense was recorded" },
        "deductFromBalance": { "type": "boolean", "description": "Whether this expense should be deducted from the main balance" }
      },
      "required": ["description", "amount", "date", "deductFromBalance"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A deposit record",
      "type": "object",
      "properties": {
        "memberId": { "type": "string", "description": "ID of the member who made the deposit" },
        "amount": { "type": "number", "description": "Amount deposited" },
        "date": { "type": "string", "format": "date-time", "description": "When the deposit was made" },
        "month": { "type": "string", "description": "The month this deposit is for (e.g., '2023-10')" },
        "type": { "type": "string", "enum": ["monthly", "yearly"], "description": "Type of deposit" }
      },
      "required": ["memberId", "amount", "date", "month"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global group settings",
      "type": "object",
      "properties": {
        "duration": { "type": "number", "description": "Duration in months for calculations" },
        "startDate": { "type": "string", "description": "The month the savings group started (e.g., '2023-01')" },
        "announcement": { "type": "string", "description": "Scrolling announcement text" },
        "showAnnouncement": { "type": "boolean", "description": "Whether to show the announcement bar" },
        "announcementSpeed": { "type": "number", "description": "Scrolling speed in seconds (higher is slower)" },
        "tagline1": { "type": "string", "description": "Primary tagline text" },
        "tagline2": { "type": "string", "description": "Secondary tagline text" },
        "heroTitle": { "type": "string", "description": "Main title on the public page" },
        "heroSubtitle": { "type": "string", "description": "Subtitle on the public page" },
        "dueStartDate": { "type": "number", "description": "Day of the month when dues start appearing (e.g., 15)" },
        "dueEndDate": { "type": "number", "description": "Day of the month when dues become critical (e.g., 20)" },
        "showContactPersons": { "type": "boolean" },
        "contactPerson1": { "$ref": "ContactPerson" },
        "contactPerson2": { "$ref": "ContactPerson" },
        "contactPerson3": { "$ref": "ContactPerson" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["duration", "startDate"]
    }
  },
  "firestore": {
    "/members": { "schema": "Member", "description": "Collection of group members" },
    "/transactions": { "schema": "Transaction", "description": "History of all deposits" },
    "/settings": { "schema": "Settings", "description": "Global configuration" },
    "/profits": { "schema": "Profit", "description": "History of group profits" },
    "/expenses": { "schema": "Expense", "description": "History of group expenses" }
  }
}
