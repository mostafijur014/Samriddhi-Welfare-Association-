rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'admin@prosperity.local';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    match /members/{memberId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(memberId);
    }

    match /transactions/{transactionId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(transactionId);
    }

    match /profits/{profitId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(profitId);
    }

    match /expenses/{expenseId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(expenseId);
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(settingId);
    }
  }
}
